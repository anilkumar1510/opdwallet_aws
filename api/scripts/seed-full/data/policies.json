"__v":0},{"_id":{"$oid":"6984853fd8c961318d9e90e9"},"policyNumber":"POL-2026-0005","name":"HCL Healthcare OPD Wallet","description":"The OPD Wallet is a digital benefit designed to simplify and streamline access to Outpatient Department (OPD) healthcare services. It enables eligible members to utilize a pre-defined OPD benefit amount for a wide range of medical expenses through a single, integrated platform.\n\nUnder this policy, a fixed OPD wallet balance is allocated to the member for a specified policy period. This balance can be used to pay for eligible outpatient healthcare services such as doctor consultations, diagnostic tests, medicines, and other covered medical expenses, as defined in the policy terms.\n\nThe OPD Wallet offers a cashless and/or reimbursement-based experience, allowing members to conveniently book services, make payments, and track utilization in real time through the member portal or mobile application. Each transaction is validated against the policy rules, coverage limits, sub-limits (if any), and remaining wallet balance to ensure compliance with the policy.","ownerPayer":"INSURER","status":"ACTIVE","effectiveFrom":{"$date":"2026-02-05T00:00:00Z"},"effectiveTo":{"$date":"2028-06-05T00:00:00Z"},"createdBy":"693d752d8990f4b120255ee7","createdAt":{"$date":"2026-02-05T11:55:43.778Z"},"updatedAt":{"$date":"2026-02-05T11:55:43.778Z"},"__v":0},{"_id":{"$oid":"69b8e4385ba6e900c12de734"},"policyNumber":"POL-2026-0006","name":"HCL Healthcare OPD Wallet Plan","ownerPayer":"CORPORATE","status":"ACTIVE","effectiveFrom":{"$date":"2026-03-17T00:00:00Z"},"effectiveTo":{"$date":"2027-05-24T00:00:00Z"},"createdBy":"693d752d8990f4b120255ee7","createdAt":{"$date":"2026-03-17T05:18:48.334Z"},"updatedAt":{"$date":"2026-03-17T05:19:00.873Z"},"__v":0,"description":"","updatedBy":"693d752d8990f4b120255ee7"},{"_id":{"$oid":"69ca09f25ba6e900c12df438"},"policyNumber":"POL-2026-0007","name":"HCL Health All","ownerPayer":"CORPORATE","status":"ACTIVE","effectiveFrom"