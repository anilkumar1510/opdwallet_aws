partialPaymentEnabled":false,"carryForward":{"enabled":false,"percent":0,"months":0},"topUpAllowed":true},"policyDescription":{"inclusions":[{"headline":"Consult (Online & Offline)","description":"Description: Covers medical consultations with qualified doctors through both in-person visits and teleconsultations. Benefit: Enables timely access to medical advice, second opinions, and follow-up care without location constraints."},{"headline":"Pharmacy (1mg Partner)","description":"Description: Covers diagnostic laboratory tests including pathology and cardiology investigations. Benefit: Supports early detection, accurate diagnosis, and effective monitoring of health conditions."},{"headline":"Diagnostic (Radiology & Endoscopy)","description":"Description: Includes advanced diagnostic procedures such as radiology imaging and endoscopic examinations. Benefit: Enables detailed internal assessments to support precise diagnosis and treatment planning."},{"headline":"Dental","description":"Description: Covers basic dental procedures including consultation, oral examination, cleaning, and scaling. Benefit: Promotes oral hygiene, prevents dental diseases, and reduces long-term dental treatment costs."},{"headline":"Vision","description":"Description: Includes eye check-ups and coverage for corrective lenses as per policy limits. Benefit: Helps maintain eye health, early detection of vision issues, and correction of refractive errors."},{"headline":"Wellness (Annual Health Check)","description":"Description: Provides coverage for an annual preventive health check-up. Benefit: Encourages proactive health monitoring and early identification of potential health risks."}],"exclusions":[{"headline":"Pre-Existing Diseases (Waiting Period Applicable)","description":"Description: Medical conditions or illnesses existing prior to the policy start date are excluded until the specified waiting period is completed. Benefit: Ensures risk is assessed fairly while allowing coverage after continuous policy tenure."},{"headline":"Cosmetic & Aesthetic Treatments","description":"Description: Procedures undertaken for cosmetic or aesthetic purposes, unless medically necessary, are excluded. Benefit: Limits coverage to medically required treatments only."},{"headline":"Self-Inflicted Injuries & Suicide Attempts","description":"Description: Injuries or treatments arising from intentional self-harm or suicide attempts are excluded. Benefit: Excludes non-accidental medical events from coverage."},{"headline":"Experimental or Unproven Treatments","description":"Description: Treatments, drugs, or procedures not recognized by standard medical practice are excluded. Benefit: Ensures coverage is limited to evidence-based medical care."},{"headline":"Non-Prescribed Medicines & Supplements","description":"Description: Medicines, vitamins, or supplements not prescribed by a registered medical practitioner are excluded. Benefit: Prevents reimbursement of non-essential or over-the-counter expenses."},{"headline":"Alternative Therapies (Unless Specified)","description":"Description: Treatments under AYUSH or other alternative systems are excluded unless specifically mentioned. Benefit: Maintains clarity on covered treatment systems."}]},"coveredRelationships":["REL001","REL002"],"memberConfigs":{"REL001":{"inheritFromPrimary":true},"REL002":{"inheritFromPrimary":true}},"createdBy":"693d752d8990f4b120255ee7","updatedBy":"693d752d8990f4b120255ee7","createdAt":{"$date":"2026-02-05T12:16:07.104Z"},"updatedAt":{"$date":"2026-02-05T12:16:11.255Z"},"__v":0,"publishedAt":{"$date":"2026-02-05T12:16:11.245Z"},"publishedBy":"693d752d8990f4b120255ee7"},{"_id":{"$oid":"69b8e5b35ba6e900c12de77a"},"policyId":{"$oid":"69b8e4385ba6e900c12de734"},"version":1,"status":"PUBLISHED","isCurrent":true,"benefits":{"CAT005":{"enabled":true,"claimEnabled":true,"annualLimit":3000,"perClaimLimit":500,"allowedSpecialties":["693d75d116b936465c15218e"],"serviceTransactionLimits":{"693d75d116b936465c152