# API Base URL - Points to the same backend as web portal
# IMPORTANT: Use HTTPS in production for security compliance

# Development (local)
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Production - HTTPS is REQUIRED
# The application enforces HTTPS in production mode.
# Using HTTP in production will cause a security error.
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api

# Session inactivity timeout in minutes (default: 15 minutes)
# HIPAA recommends automatic logoff after period of inactivity
EXPO_PUBLIC_SESSION_TIMEOUT_MINUTES=15
